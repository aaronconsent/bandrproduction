{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bandrproduction",
  "compatibility_date": "2026-05-28",
  "main": "worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "triggers": {
    // Monday 13:00 UTC ≈ 08:00 America/Chicago — weekly lead digest email
    "crons": ["0 13 * * 1"]
  }
}
